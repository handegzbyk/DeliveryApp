@page "/"
@using ShopDelivery.Shared
@inject ShopApiClient Api

<PageTitle>SmartBasket · Your grocery rhythm</PageTitle>

<section class="hero">
    <div class="eyebrow">Your grocery rhythm</div>
    <h1>A basket that gets more personal with every receipt.</h1>
    <p>
        Confirm what you bought, keep your monthly budget current, and receive suggestions shaped by your own habits.
    </p>
    <a class="button-primary" href="scan">Scan a receipt</a>
</section>

@if (_busy)
{
    <p><em>Preparing your overview…</em></p>
}
else if (_latestExpense is null)
{
    <section class="app-card">
        <div class="eyebrow">Start your story</div>
        <h2>Your budget is ready for its first receipt.</h2>
        <p class="muted">Scan, confirm each product, and the basket will be added to your personal monthly view.</p>
        <a class="button-primary" href="scan">Add my first receipt</a>
    </section>
}
else
{
    <section class="dashboard-grid">
        <article class="app-card">
            <div class="eyebrow">Spent this month</div>
            <div class="metric">@_latestExpense.Dashboard.Spent.ToString("C")</div>
            <p class="muted">Across your confirmed receipts.</p>
        </article>
        <article class="app-card">
            <div class="eyebrow">Still available</div>
            <div class="metric">@_latestExpense.Dashboard.Remaining.ToString("C")</div>
            <p class="muted">From @_latestExpense.Dashboard.MonthlyBudget.ToString("C") this month.</p>
        </article>
        <article class="app-card">
            <div class="eyebrow">Latest basket</div>
            <h2>@_latestExpense.Total.ToString("C")</h2>
            <p class="muted">@_latestExpense.StoreName · @_latestExpense.PurchasedAt.ToString("d")</p>
            <a href="@($"budget/{_latestExpense.ReceiptId}")">Open basket detail</a>
        </article>
    </section>

    <p><a class="button-primary" href="expenses">Open my full budget</a></p>
}

<section class="feature-grid">
    <article class="app-card">
        <div class="eyebrow">For your next trip</div>
        <h2>Personal recommendations</h2>
        <p class="muted">Suggestions become more relevant as your confirmed basket history grows.</p>
        <a href="recommendations">See my recommendations</a>
    </article>
    <article class="app-card">
        <div class="eyebrow">Your rewards</div>
        <h2>Loyalty that follows you</h2>
        <p class="muted">Turn receipt scans and confirmed matches into visible progress.</p>
        <a href="loyalty">Open my loyalty</a>
    </article>
    <article class="app-card">
        <div class="eyebrow">Your next basket</div>
        <h2>Plan before you shop</h2>
        <p class="muted">Build a list from your habits and prepare it for shopping or delivery.</p>
        <a href="shop">Plan a basket</a>
    </article>
</section>

@if (_error is not null)
{
    <p class="error" role="alert">@_error</p>
}

@code {
    private BasketExpenseResponse? _latestExpense;
    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        _busy = true;

        try
        {
            _latestExpense = await Api.GetLatestExpenseAsync();
        }
        catch (Exception ex)
        {
            _error = $"Your overview could not be loaded. {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
