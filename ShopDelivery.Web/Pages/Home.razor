@page "/"
@using ShopDelivery.Shared
@inject ShopApiClient Api

<PageTitle>SmartBasket</PageTitle>

<section class="hero">
    <div class="eyebrow">Smart grocery operating system</div>
    <h1>Scan receipts, learn stores, plan baskets, and route delivery.</h1>
    <p>
        Products are seeded from OpenFoodFacts, receipt names are learned per market,
        and confirmed baskets become expense insights plus future recommendations.
    </p>
    <a class="button-primary" href="scan">Scan receipt</a>
</section>

@if (_busy)
{
    <p><em>Loading overview…</em></p>
}
else
{
    <section class="dashboard-grid">
        <article class="app-card">
            <div class="eyebrow">Catalog</div>
            <div class="metric">@_products.Count</div>
            <p class="muted">OpenFoodFacts products ready for receipt matching.</p>
            <button class="primary" @onclick="SeedCatalog" disabled="@_seeding">
                @(_seeding ? "Seeding…" : "Seed starter catalog")
            </button>
            @if (_message is not null)
            {
                <p class="muted">@_message</p>
            }
        </article>

        <article class="app-card">
            <div class="eyebrow">Expense</div>
            <h2>@(_latestExpense?.Total.ToString("C") ?? "No basket yet")</h2>
            <p class="muted">
                @(_latestExpense is null
                    ? "Confirm a scanned receipt to unlock the budget dashboard."
                    : $"{_latestExpense.StoreName} · {_latestExpense.PurchasedAt:d}")
            </p>
            <a href="expenses">Open expense dashboard</a>
        </article>

        <article class="app-card">
            <div class="eyebrow">Warnings</div>
            <h2>@WarningCount</h2>
            <p class="muted">Products missing images, categories, prices, or OpenFoodFacts codes.</p>
            <a href="catalog-health">Review catalog health</a>
        </article>
    </section>

    <section class="feature-grid">
        <article class="app-card">
            <h2>Earn loyalty points</h2>
            <p class="muted">Reward receipt scans, confirmed matches, and basket delivery orders.</p>
            <a href="loyalty">Open loyalty</a>
        </article>
        <article class="app-card">
            <h2>Get recommendations</h2>
            <p class="muted">Use your catalog and basket history to suggest useful grocery items.</p>
            <a href="recommendations">Open recommendations</a>
        </article>
        <article class="app-card">
            <h2>Shop and deliver</h2>
            <p class="muted">Create a shopping list, compare nearby markets, and prepare delivery.</p>
            <a href="shop">Open basket builder</a>
        </article>
    </section>
}

@if (_error is not null)
{
    <p class="error" role="alert">@_error</p>
}

@code {
    private List<ProductSummary> _products = [];
    private BasketExpenseResponse? _latestExpense;
    private string? _message;
    private string? _error;
    private bool _busy;
    private bool _seeding;

    private int WarningCount =>
        _products.Count(product =>
            string.IsNullOrWhiteSpace(product.ImageUrl)
            || string.IsNullOrWhiteSpace(product.Category)
            || string.IsNullOrWhiteSpace(product.OpenFoodFactsCode)
            || product.LatestPrice is null);

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _busy = true;
        _error = null;

        try
        {
            _products = (await Api.GetProductsAsync()).ToList();
            _latestExpense = await Api.GetLatestExpenseAsync();
        }
        catch (Exception ex)
        {
            _error = $"Couldn't load overview: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SeedCatalog()
    {
        _seeding = true;
        _message = null;
        _error = null;

        try
        {
            var result = await Api.SeedProductCatalogAsync();
            _message = $"{result.Created} created, {result.Updated} updated, {result.Skipped} already existed.";
            _products = (await Api.GetProductsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Couldn't seed catalog: {ex.Message}";
        }
        finally
        {
            _seeding = false;
        }
    }

}
