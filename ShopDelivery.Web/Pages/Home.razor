@page "/"
@using ShopDelivery.Shared
@inject ShopApiClient Api

<PageTitle>Products</PageTitle>

<h1>Products</h1>

<div class="product-import">
    <input @bind="_query" @bind:event="oninput" placeholder="Search OpenFoodFacts, e.g. oat milk" />
    <button class="primary" @onclick="ImportProduct" disabled="@_busy">Import from API</button>
    <button @onclick="SeedCatalog" disabled="@_busy">Seed starter catalog</button>
</div>

@if (_error is not null)
{
    <p class="error" role="alert">@_error</p>
}

@if (_message is not null)
{
    <p>@_message</p>
}

@if (_busy)
{
    <p><em>Loading…</em></p>
}
else if (_products.Count == 0)
{
    <p>No products saved yet. Import one above or confirm a receipt.</p>
}
else
{
    <div class="product-grid">
        @foreach (var product in _products)
        {
            <article class="product-card">
                @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                {
                    <img src="@product.ImageUrl" alt="@product.Name" />
                }
                <div>
                    <h2>@product.Name</h2>
                    <p>@(product.BrandName ?? "No brand")</p>
                    @if (!string.IsNullOrWhiteSpace(product.OpenFoodFactsCode))
                    {
                        <p>OpenFoodFacts: @product.OpenFoodFactsCode</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(product.Category))
                    {
                        <p>@product.Category</p>
                    }
                    @if (product.LatestPrice is { } price)
                    {
                        <p>@price.ToString("C")</p>
                    }
                </div>
            </article>
        }
    </div>
}

@code {
    private List<ProductSummary> _products = [];
    private string? _query;
    private string? _error;
    private string? _message;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        _error = null;
        _message = null;
        _busy = true;

        try
        {
            _products = (await Api.GetProductsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Couldn't load products: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ImportProduct()
    {
        if (string.IsNullOrWhiteSpace(_query))
            return;

        _error = null;
        _message = null;
        _busy = true;

        try
        {
            await Api.ImportProductAsync(_query);
            _query = null;
            _products = (await Api.GetProductsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Couldn't import product: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SeedCatalog()
    {
        _error = null;
        _message = null;
        _busy = true;

        try
        {
            var result = await Api.SeedProductCatalogAsync();
            _message = $"Seeded catalog: {result.Created} created, {result.Updated} updated, {result.Skipped} already present.";
            _products = (await Api.GetProductsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Couldn't seed catalog: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
