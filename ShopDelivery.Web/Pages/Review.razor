@page "/review"
@page "/scan"
@using ShopDelivery.Shared
@inject ShopApiClient Api
@inject NavigationManager Nav

<h3>Review receipt</h3>

@if (_model is null)
{
    <p class="review-help">
        Upload a receipt. The app reads the store name, matches each item against learned store names first,
        then uses the OpenFoodFacts catalog and images for confirmation.
    </p>
    <InputFile OnChange="OnFile" accept="image/*" />
    @if (_busy)
    {
        <p>Scanning receipt, matching store items, and loading product images…</p>
    }
}
else
{
    <section class="receipt-summary">
        <div>
            <div class="label">Store</div>
            <strong>@_model.StoreName</strong>
        </div>
        <div>
            <div class="label">Date</div>
            <strong>@_model.PurchasedAt.ToString("d")</strong>
        </div>
        <div>
            <div class="label">Total</div>
            <strong>@_model.Total.ToString("C")</strong>
        </div>
    </section>

    <p class="review-help">
        Confirmed lines save the receipt name under <b>@_model.StoreName</b>, so future scans match this store's
        wording faster. Prices are saved for this store and date.
    </p>

    @foreach (var row in _rows)
    {
        <div class="review-row">
            <div class="raw">
                <span>@row.RawText</span>
                <strong>@row.Price.ToString("C") @(row.Quantity > 1 ? $"×{row.Quantity}" : "")</strong>
            </div>

            @if (row.IsMatched)
            {
                @* MATCHED → show the selected product image too *@
                <div class="matched-product">
                    <div class="matched-image">
                        @if (!string.IsNullOrWhiteSpace(row.SelectedCandidate?.ImageUrl))
                        {
                            <img src="@row.SelectedCandidate.ImageUrl" alt="@row.SelectedName" />
                        }
                        else
                        {
                            <div class="image-placeholder">No image</div>
                        }
                    </div>
                    <div>
                        <div class="matched">✔ Matched</div>
                        <div class="matched-name">@row.SelectedName</div>
                        <div class="hint">Will save as a @(_model.StoreName) store item on confirmation.</div>
                        <button class="link" @onclick="() => row.IsMatched = false">Change match</button>
                    </div>
                </div>
            }
            else
            {
                @* UNMATCHED → sliding gallery of candidates *@
                <div class="hint">Choose the right product image/name, or keep the new item card.</div>
                <div class="gallery">
                    @foreach (var c in row.Candidates)
                    {
                        <div class="card @(row.SelectedCandidate == c ? "selected" : "")"
                             @onclick="() => row.Select(c)">
                            @if (!string.IsNullOrEmpty(c.ImageUrl))
                            {
                                <img src="@c.ImageUrl" alt="@c.Name" />
                            }
                            else
                            {
                                <div class="image-placeholder">No image</div>
                            }
                            <div class="name">@(c.ProductId is null ? $"+ New: {c.Name}" : c.Name)</div>
                        </div>
                    }
                </div>

                @* brand chips for the chosen (new) product *@
                @if (row.SelectedCandidate?.ProductId is null)
                {
                    <div class="brand-slider">
                        @foreach (var b in row.BrandOptions)
                        {
                            <button class="chip @(row.SelectedBrandId == b.BrandId ? "selected" : "")"
                                    @onclick="() => row.SelectedBrandId = b.BrandId">@b.Name</button>
                        }
                        <input @bind="row.NewBrandName" placeholder="+ new brand" />
                    </div>
                }
            }
        </div>
    }

    <button class="primary" @onclick="Confirm" disabled="@_busy">Confirm basket</button>
}

@code {
    ScanReviewResponse? _model;
    List<RowVm> _rows = new();
    bool _busy;

    async Task OnFile(InputFileChangeEventArgs e)
    {
        _busy = true;
        _model = await Api.ReviewAsync(e.File);
        _rows = _model.Lines.Select(l => new RowVm(l)).ToList();
        _busy = false;
    }

    async Task Confirm()
    {
        _busy = true;
        var req = new ConfirmRequest(
            _model!.StoreName, _model.PurchasedAt, _model.Total,
            _rows.Select(r => r.ToConfirmLine()).ToList());
        var receiptId = await Api.ConfirmAsync(req);
        _busy = false;
        Nav.NavigateTo($"/budget/{receiptId}");   // → next: budget page
    }

    class RowVm
    {
        readonly ReviewLine _l;
        public RowVm(ReviewLine l)
        {
            _l = l;
            IsMatched = l.MatchedProductId is not null;
            SelectedCandidate = l.Candidates
                .FirstOrDefault(c => c.ProductId == l.MatchedProductId) ?? l.Candidates.FirstOrDefault();
        }

        public string RawText => _l.RawText;
        public decimal Price => _l.Price;
        public int Quantity => _l.Quantity;
        public List<ProductCandidate> Candidates => _l.Candidates;
        public List<BrandOption> BrandOptions => _l.BrandOptions;

        public bool IsMatched { get; set; }
        public ProductCandidate? SelectedCandidate { get; set; }
        public int? SelectedBrandId { get; set; }
        public string? NewBrandName { get; set; }

        public string SelectedName => SelectedCandidate?.Name ?? RawText;

        public void Select(ProductCandidate c) => SelectedCandidate = c;

        public ConfirmLine ToConfirmLine() => new(
            RawText, Price, Quantity,
            SelectedCandidate?.ProductId,
            SelectedCandidate?.Name ?? RawText,
            SelectedBrandId, NewBrandName);
    }
}
