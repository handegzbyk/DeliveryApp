@page "/admin"
@attribute [Authorize(Roles = "admin")]
@using ShopDelivery.Shared
@inject ShopApiClient Api

<PageTitle>Admin · Master data</PageTitle>

<section class="admin-hero">
    <div class="eyebrow">Administration</div>
    <h1>Build and protect the shared product catalog.</h1>
    <p>Search before creating products, review uncertain submissions, and merge duplicates without changing customer receipts.</p>
</section>

@if (_busy)
{
    <p><em>Loading administration workspace…</em></p>
}
else
{
    <section class="dashboard-grid">
        <article class="app-card">
            <div class="eyebrow">API</div>
            <h2>@(_health?.Status ?? "Unavailable")</h2>
        </article>
        <article class="app-card">
            <div class="eyebrow">Confirmed products</div>
            <div class="metric">@_products.Count</div>
        </article>
        <article class="app-card">
            <div class="eyebrow">Waiting for review</div>
            <div class="metric">@_reviews.Count</div>
        </article>
    </section>

    <section class="admin-grid">
        <article class="app-card">
            <h2>Search before adding</h2>
            <p class="muted">Search the EDEKA-seeded master catalog by name, barcode, or OCR text from a package photo.</p>
            <div class="import-row">
                <input @bind="_searchText" placeholder="Product name or EAN" aria-label="Product name or EAN" />
                <button @onclick="SearchByName" disabled="@(_working || string.IsNullOrWhiteSpace(_searchText))">Search</button>
            </div>
            <label class="receipt-picker">
                <span>Search package image with OCR</span>
                <InputFile OnChange="SearchByImage" accept="image/*" disabled="@_working" />
            </label>

            @if (_search is not null)
            {
                <p><strong>Search text:</strong> @_search.Query</p>
                <div class="admin-search-results">
                    @foreach (var candidate in _search.Candidates)
                    {
                        <div class="confirmed-item">
                            <span class="confirmed-thumbnail">
                                <img src="@candidate.ImageUrl" alt="" loading="lazy" />
                            </span>
                            <span><strong>@candidate.Name</strong><small>@candidate.MatchReason · @candidate.Score.ToString("P0")</small></span>
                        </div>
                    }
                </div>
                @if (!_search.ExactMatch && !string.IsNullOrWhiteSpace(_searchText))
                {
                    <button class="primary" @onclick="SubmitNewProposal" disabled="@_working">
                        Submit as uncertain new product
                    </button>
                }
            }
        </article>

        <article class="app-card">
            <h2>Administrator review queue</h2>
            @if (_reviews.Count == 0)
            {
                <p class="muted">Nothing is waiting for review.</p>
            }
            @foreach (var editor in _reviews)
            {
                <div class="review-admin-item">
                    <strong>@editor.Item.ProposedProductName</strong>
                    <span>@editor.Item.SourceType · @editor.Item.RawName</span>
                    @if (editor.IsAliasReview)
                    {
                        <span>This review changes a store alias; rejecting it will not reject either master product.</span>
                    }
                    @if (editor.Item.CandidateProductId is not null)
                    {
                        <span>Possible existing product: @editor.Item.CandidateProductName (#@editor.Item.CandidateProductId)</span>
                    }
                    <div class="review-fields">
                        <label>Name <input @bind="editor.Name" /></label>
                        <label>EAN / GTIN <input @bind="editor.Gtin" /></label>
                        <label>Brand <input @bind="editor.Brand" /></label>
                        <label>Category <input @bind="editor.Category" /></label>
                    </div>
                    <label class="receipt-picker compact-picker">
                        <span>@(editor.Item.HasImage ? "Replace product image" : "Add product image")</span>
                        <InputFile OnChange="@(args => UploadReviewImage(editor, args))" accept="image/*" disabled="@_working" />
                    </label>
                    <div class="admin-actions">
                        <button @onclick='() => Decide(editor, "confirm")' disabled="@_working">
                            @(editor.IsAliasReview ? "Accept mapping correction" : "Save & confirm new")
                        </button>
                        <button @onclick='() => Decide(editor, "merge")'
                                disabled="@(_working || editor.Item.CandidateProductId is null)">Merge duplicate products</button>
                        <button @onclick='() => Decide(editor, "reject")' disabled="@_working">
                            @(editor.IsAliasReview ? "Keep existing mapping" : "Reject product")
                        </button>
                    </div>
                </div>
            }
        </article>
    </section>
}

@if (_message is not null)
{
    <p class="status-message">@_message</p>
}
@if (_error is not null)
{
    <p class="error" role="alert">@_error</p>
}

@code {
    private ApiHealthResponse? _health;
    private List<ProductSummary> _products = [];
    private List<ReviewEditor> _reviews = [];
    private ProductSearchResponse? _search;
    private string? _searchText;
    private string? _message;
    private string? _error;
    private bool _busy = true;
    private bool _working;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _busy = true;
        try
        {
            _health = await Api.GetHealthAsync();
            _products = (await Api.GetProductsAsync()).ToList();
            _reviews = (await Api.GetProductReviewsAsync()).Select(item => new ReviewEditor(item)).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Administration data could not be loaded. {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SearchByName()
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return;
        await Work(async () => _search = await Api.SearchProductsAsync(_searchText.Trim()));
    }

    private async Task SearchByImage(InputFileChangeEventArgs args)
    {
        await Work(async () =>
        {
            _search = await Api.SearchProductImageAsync(args.File);
            _searchText = _search.Query;
        });
    }

    private async Task SubmitNewProposal()
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return;
        await Work(async () =>
        {
            var response = await Api.ProposeProductAsync(new ProductProposalRequest(
                _searchText.Trim(),
                CreateWhenUncertain: true));
            _message = response.Created ? "Proposal added for administrator confirmation." : "An existing match was found.";
            _reviews = (await Api.GetProductReviewsAsync()).Select(item => new ReviewEditor(item)).ToList();
        });
    }

    private async Task UploadReviewImage(ReviewEditor editor, InputFileChangeEventArgs args)
    {
        await Work(async () =>
        {
            await Api.UploadProductImageAsync(editor.Item.ProposedProductId, args.File);
            _message = "Product image saved with the proposed master-data record.";
            var refreshed = await Api.GetProductReviewsAsync();
            _reviews = refreshed.Select(item => new ReviewEditor(item)).ToList();
        });
    }

    private async Task Decide(ReviewEditor editor, string action)
    {
        await Work(async () =>
        {
            await Api.DecideProductReviewAsync(editor.Item.Id, new AdminReviewDecision(
                action,
                action == "merge" ? editor.Item.CandidateProductId : null,
                editor.Name,
                editor.Gtin,
                editor.Brand,
                editor.Category));
            _message = $"Review #{editor.Item.Id} completed: {action}.";
            _reviews = (await Api.GetProductReviewsAsync()).Select(item => new ReviewEditor(item)).ToList();
            _products = (await Api.GetProductsAsync()).ToList();
        });
    }

    private async Task Work(Func<Task> action)
    {
        _working = true;
        _error = null;
        _message = null;
        try { await action(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _working = false; }
    }

    private sealed class ReviewEditor(AdminReviewItem item)
    {
        public AdminReviewItem Item { get; } = item;
        public string Name { get; set; } = item.ProposedProductName;
        public string? Gtin { get; set; } = item.ProposedGtin;
        public string? Brand { get; set; } = item.ProposedBrandName;
        public string? Category { get; set; } = item.ProposedCategory;
        public bool IsAliasReview => Item.SourceType is "AliasCorrection" or "CatalogAliasConflict";
    }
}
